<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         LingoLens design tokens — "Optical Instrument"
         Warm graphite + a single brass accent. Deliberately NOT a
         SaaS purple gradient. Precision-tool detailing: hairlines,
         mono telemetry, an aperture brand mark.
         ============================================================ -->

    <!-- Surfaces (warm near-black, layered elevation) -->
    <Color x:Key="BackgroundColor">#0C0C0E</Color>
    <Color x:Key="SurfaceColor">#151417</Color>
    <Color x:Key="SurfaceAltColor">#1F1D22</Color>
    <Color x:Key="SurfaceRaisedColor">#26232A</Color>
    <Color x:Key="BorderColor">#2A2830</Color>
    <Color x:Key="BorderStrongColor">#3C3945</Color>

    <!-- Text (warm whites/greys) -->
    <Color x:Key="TextPrimaryColor">#F4F1EA</Color>
    <Color x:Key="TextSecondaryColor">#A9A39A</Color>
    <Color x:Key="TextTertiaryColor">#716B62</Color>

    <!-- Accent: brass / amber -->
    <Color x:Key="AccentColor">#E0A45C</Color>
    <Color x:Key="AccentColor2">#F1C485</Color>
    <Color x:Key="AccentPressedColor">#C68A41</Color>
    <Color x:Key="AccentInkColor">#1A1206</Color>   <!-- text on brass -->

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#6FBF8E</Color>
    <Color x:Key="WarningColor">#E0B05C</Color>
    <Color x:Key="DangerColor">#E0746B</Color>

    <!-- ============ Brushes ============ -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#211F26" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentInkBrush" Color="{StaticResource AccentInkColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#22E0A45C" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

    <!-- Brass sheen for the single primary action -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource AccentColor2}" Offset="0" />
        <GradientStop Color="{StaticResource AccentColor}" Offset="0.55" />
        <GradientStop Color="{StaticResource AccentPressedColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Subtle top highlight hairline for cards (light-from-above) -->
    <LinearGradientBrush x:Key="CardSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#14FFFFFF" Offset="0" />
        <GradientStop Color="#00FFFFFF" Offset="0.18" />
    </LinearGradientBrush>

    <!-- ============ Typography ============
         Bahnschrift (technical DIN-style, ships with Windows) for display/labels,
         Cascadia Mono for instrument readouts, Segoe UI Variable for body. -->
    <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="DisplayFont">Bahnschrift SemiBold, Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="DisplayFontLight">Bahnschrift Light, Bahnschrift, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas</FontFamily>

</ResourceDictionary>
