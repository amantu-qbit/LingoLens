<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         LingoLens design tokens
         A quiet, near-monochrome dark interface with a single mint
         accent used sparingly. High text contrast, hairline borders,
         flat surfaces — no glows, no gradients, no decoration for its
         own sake. Built on an 8px spacing rhythm.
         ============================================================ -->

    <!-- Surfaces: neutral, near-black, layered by a few points of lightness. -->
    <SolidColorBrush x:Key="BackgroundBrush"     Color="#0D0D0F" />
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#17181B" />
    <SolidColorBrush x:Key="SurfaceAltBrush"     Color="#1E1F23" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush"  Color="#292A2F" />
    <SolidColorBrush x:Key="BorderBrush"         Color="#2B2C32" />
    <SolidColorBrush x:Key="BorderStrongBrush"   Color="#3A3B42" />
    <SolidColorBrush x:Key="HairlineBrush"       Color="#222328" />

    <!-- Text: crisp neutral whites with deliberate, readable steps. -->
    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#FAFAFA" />
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#B7B9C0" />
    <SolidColorBrush x:Key="TextTertiaryBrush"   Color="#878A93" />

    <!-- Accent: one mint, plus its hover / pressed / ink-on-mint variants. -->
    <SolidColorBrush x:Key="AccentBrush"         Color="#4FD6B8" />
    <SolidColorBrush x:Key="AccentHoverBrush"    Color="#67E0C6" />
    <SolidColorBrush x:Key="AccentPressedBrush"  Color="#3BB89C" />
    <SolidColorBrush x:Key="AccentInkBrush"      Color="#06140F" />
    <SolidColorBrush x:Key="AccentSoftBrush"     Color="#224FD6B8" />
    <SolidColorBrush x:Key="AccentDimBrush"      Color="#6E4FD6B8" />

    <!-- Semantic (used rarely, kept close to the monochrome mood). -->
    <SolidColorBrush x:Key="SuccessBrush"        Color="#56D49A" />
    <SolidColorBrush x:Key="WarningBrush"        Color="#E2C275" />
    <SolidColorBrush x:Key="DangerBrush"         Color="#E06C6C" />

    <!-- Colors kept as Color tokens for places that need a Color (shadows, etc.). -->
    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="AccentColor">#4FD6B8</Color>

    <!-- ============ Typography ============
         Segoe UI Variable for everything (ships with Windows 11; falls back to
         Segoe UI). Cascadia Mono for numeric instrument readouts. Weight, size
         and color carry the hierarchy — not extra font families. -->
    <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas</FontFamily>

</ResourceDictionary>
