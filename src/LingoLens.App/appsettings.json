{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "LingoLens": {
    "Capture": {
      "MaxFps": 30,
      "CaptureCursor": false,
      "ShowCaptureBorder": false,
      "PreferDirtyRegions": true
    },
    "Ocr": {
      "Engine": "auto",
      "MinConfidence": 0.55,
      "MaxDetectionSide": 1280,
      "Scripts": [ "Hans", "Hant" ]
    },
    "Translation": {
      "SourceLanguage": "zh",
      "TargetLanguage": "en",
      "Engine": "auto",
      "CacheCapacity": 8192,
      "ContextLines": 3,
      "UseGlossary": true
    },
    "Overlay": {
      "Style": "ReplaceInPlace",
      "BackplateOpacity": 0.72,
      "AutoContrast": true,
      "FadeMilliseconds": 120,
      "FontFamily": "Segoe UI Variable",
      "MinFontScale": 0.6
    },
    "Compute": {
      "Device": "auto",
      "MaxTier": "auto",
      "AllowCudaUpgrade": true
    },
    "Pipeline": {
      "UiDebounceMs": 100,
      "ChatDebounceMs": 50,
      "InferenceQueueDepth": 2,
      "ChangeThreshold": 0.02,
      "LatencyBudgetMs": 150
    }
  }
}
