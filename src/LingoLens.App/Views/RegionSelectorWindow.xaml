<Window x:Class="LingoLens.App.Views.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select a region"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True" Cursor="Cross"
        Background="#59000000">

    <Canvas x:Name="RootCanvas">
        <Rectangle x:Name="SelectionBox" Visibility="Collapsed"
                   Stroke="#4FD6B8" StrokeThickness="1.5" Fill="#244FD6B8" />
        <Border x:Name="Hint" Background="#E6131417" CornerRadius="10" Padding="16,11"
                BorderBrush="#2B2C32" BorderThickness="1"
                Canvas.Left="0" Canvas.Top="0">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" Stroke="#4FD6B8" StrokeThickness="1.6" VerticalAlignment="Center" Margin="0,0,9,0" />
                <TextBlock Text="Drag to select a region" Foreground="#FAFAFA"
                           FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="13" VerticalAlignment="Center" />
                <TextBlock Text="Esc to cancel" Foreground="#878A93"
                           FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="13" VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>
