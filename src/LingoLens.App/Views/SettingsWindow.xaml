<Window x:Class="LingoLens.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LingoLens — Settings"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="640" Height="760" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <FontFamily x:Key="Icons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Section header: a small mint tick + an uppercase label. -->
        <Style x:Key="SectionRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="2,0,0,12" />
        </Style>
    </Window.Resources>

    <Border Margin="16" CornerRadius="16" Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="2" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="62">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                    <Grid Width="24" Height="24" Margin="0,0,12,0">
                        <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2" />
                        <Ellipse Width="9" Height="9" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.3" Opacity="0.7" />
                        <Ellipse Width="3" Height="3" Fill="{StaticResource AccentBrush}" />
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Settings" Style="{StaticResource TitleText}" />
                        <TextBlock Text="LingoLens" Style="{StaticResource MicroText}" Margin="0,-1,0,0" />
                    </StackPanel>
                </StackPanel>
                <Button Style="{StaticResource IconButton}" Content="&#xE8BB;" HorizontalAlignment="Right"
                        Margin="0,0,16,0" VerticalAlignment="Center" Click="OnClose" />
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource HairlineBrush}" Margin="20,0" />

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,18,18,24">
                <StackPanel Margin="0,0,6,0">

                    <!-- Models -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="MODELS" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,12" TextWrapping="Wrap"
                                       Text="Translation runs entirely on your PC. Download a translator once to get started — files are saved locally and used offline." />
                            <ItemsControl ItemsSource="{Binding Models}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                        <Border Background="{StaticResource SurfaceRaisedBrush}" CornerRadius="5" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Badge}" Style="{StaticResource MicroText}" Foreground="{StaticResource AccentBrush}" />
                                                        </Border>
                                                        <TextBlock Text="{Binding SizeText}" Style="{StaticResource MicroText}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,4,0,0" />

                                                    <!-- Downloading -->
                                                    <StackPanel Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" Margin="0,11,0,2">
                                                        <ProgressBar Style="{StaticResource DarkProgressBar}" Minimum="0" Maximum="1" Value="{Binding Progress}" />
                                                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource MicroText}" Margin="0,6,0,0" />
                                                    </StackPanel>

                                                    <!-- Installed -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                                Visibility="{Binding ShowInstalled, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="&#xE73E;" FontFamily="{StaticResource Icons}" FontSize="12"
                                                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource MicroText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <!-- Error / cancelled status (only when a download was attempted) -->
                                                    <TextBlock Text="{Binding StatusText}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource MicroText}">
                                                                <Setter Property="Margin" Value="0,8,0,0" />
                                                                <Setter Property="TextWrapping" Value="Wrap" />
                                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanDownload}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StatusText}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource PrimaryButton}" Content="Download" Command="{Binding DownloadCommand}"
                                                            Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}" />
                                                    <Button Style="{StaticResource GhostButton}" Content="Cancel" Command="{Binding CancelCommand}"
                                                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Languages -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="LANGUAGES" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" />
                            <TextBlock Grid.Column="1" Text="&#xE72A;" FontFamily="{StaticResource Icons}" FontSize="14"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="2" Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}" />
                        </Grid>
                    </Border>

                    <!-- Compute -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="COMPUTE DEVICE" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <ComboBox Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding DeviceItems}" SelectedItem="{Binding SelectedDevice}" />
                            <StackPanel Orientation="Horizontal" Margin="2,12,0,0">
                                <TextBlock Text="Model tier" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="5" Padding="7,1" Margin="9,0,0,0">
                                    <TextBlock Text="{Binding TierText}" Style="{StaticResource MonoText}" FontSize="11"
                                               Foreground="{StaticResource AccentBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="2,10,0,0" TextWrapping="Wrap"
                                       Text="Auto picks the fastest available accelerator (TensorRT / CUDA → DirectML → CPU). One build runs on any GPU." />
                        </StackPanel>
                    </Border>

                    <!-- Overlay -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="OVERLAY" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Display style" Style="{StaticResource CaptionText}" Margin="2,0,0,7" />
                            <ComboBox Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding OverlayStyles}" SelectedItem="{Binding SelectedStyle}" />

                            <Grid Margin="2,18,0,0">
                                <TextBlock Text="Backplate opacity" Style="{StaticResource CaptionText}" />
                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource MonoText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding Value, ElementName=OpacitySlider, StringFormat={}{0:P0}}" />
                            </Grid>
                            <Slider x:Name="OpacitySlider" Style="{StaticResource DarkSlider}" Minimum="0.2" Maximum="1.0"
                                    Value="{Binding BackplateOpacity}" Margin="0,6,0,0" />

                            <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,16,0,16" />

                            <CheckBox Style="{StaticResource ToggleSwitch}" Content="Auto-contrast backplate"
                                      IsChecked="{Binding AutoContrast}" />

                            <Grid Margin="2,18,0,0">
                                <TextBlock Text="Minimum text scale" Style="{StaticResource CaptionText}" />
                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource MonoText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding Value, ElementName=ScaleSlider, StringFormat={}{0:P0}}" />
                            </Grid>
                            <Slider x:Name="ScaleSlider" Style="{StaticResource DarkSlider}" Minimum="0.4" Maximum="1.0"
                                    Value="{Binding MinFontScale}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Glossary -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="GLOSSARY" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="2,0,0,12" TextWrapping="Wrap"
                                       Text="Custom term overrides always win over machine translation." />
                            <ItemsControl ItemsSource="{Binding GlossaryEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="9" Padding="12,8" Margin="0,0,0,7"
                                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Source}" Style="{StaticResource BodyText}" />
                                                    <TextBlock Text="&#xE72A;" FontFamily="{StaticResource Icons}" FontSize="11"
                                                               Foreground="{StaticResource TextTertiaryBrush}" Margin="9,1,9,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Target}" Style="{StaticResource BodyText}"
                                                               Foreground="{StaticResource AccentBrush}" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="26" Height="26"
                                                        Content="&#xE74D;"
                                                        Command="{Binding DataContext.RemoveGlossaryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}" Margin="0,0,7,0"
                                         Text="{Binding NewGlossarySource, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Margin="0,0,7,0"
                                         Text="{Binding NewGlossaryTarget, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="Add"
                                        Command="{Binding AddGlossaryCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- About -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="LingoLens" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,5,0,0" TextWrapping="Wrap"
                                       Text="On-device screen translation. Nothing you see ever leaves your PC — capture, OCR and translation all run locally. Toggle the bar any time with Ctrl+Alt+H." />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
