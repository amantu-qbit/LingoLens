<Window x:Class="LingoLens.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:LingoLens.App.Ui"
        Title="LingoLens — Settings"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="664" Height="788" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <!-- Section label: a short amber bar + an uppercase label. -->
        <Style x:Key="SectionRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Margin" Value="2,0,0,12" />
        </Style>
    </Window.Resources>

    <Border x:Name="Root" Margin="16" CornerRadius="18" Background="{StaticResource CanvasBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="OnDrag" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="Lift" Y="12" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="4" Opacity="0.6" Color="Black" />
        </Border.Effect>
        <Border.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.20"
                                         EasingFunction="{StaticResource EaseOut}" />
                        <DoubleAnimation Storyboard.TargetName="Lift" Storyboard.TargetProperty="Y"
                                         From="12" To="0" Duration="0:0:0.26" EasingFunction="{StaticResource EaseOut}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="66">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="26,0,0,0">
                    <Grid Width="26" Height="26" Margin="0,0,13,0">
                        <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2" />
                        <Ellipse Width="10" Height="10" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.3" Opacity="0.6" />
                        <Ellipse Width="3.5" Height="3.5" Fill="{StaticResource AccentBrush}" />
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Settings" Style="{StaticResource TitleText}" />
                        <TextBlock Text="On-device · private by design" Style="{StaticResource MicroText}" Margin="0,-1,0,0" />
                    </StackPanel>
                </StackPanel>
                <Button Style="{StaticResource IconButton}" Content="&#xE8BB;" HorizontalAlignment="Right"
                        Margin="0,0,18,0" VerticalAlignment="Center" Click="OnClose"
                        AutomationProperties.Name="Close settings" />
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource HairlineBrush}" Margin="22,0" />

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="26,20,20,26">
                <StackPanel Margin="0,0,6,0">

                    <!-- Models -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="MODELS" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,13" TextWrapping="Wrap" LineHeight="18"
                                       Text="Translation runs entirely on your PC. Download a translator once — files are saved locally and used offline, forever." />
                            <ItemsControl ItemsSource="{Binding Models}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="11" Padding="15,13" Margin="0,0,0,9"
                                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Title}" Style="{StaticResource BodyStrong}" VerticalAlignment="Center" />
                                                        <Border Style="{StaticResource Badge}" Background="{StaticResource AccentSoftBrush}" Margin="9,0,0,0">
                                                            <TextBlock Text="{Binding Badge}" Style="{StaticResource MicroText}" Foreground="{StaticResource AccentBrush}" />
                                                        </Border>
                                                        <TextBlock Text="{Binding SizeText}" Style="{StaticResource MicroText}" Margin="9,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,5,0,0" LineHeight="17" />

                                                    <!-- Downloading -->
                                                    <StackPanel Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" Margin="0,12,0,2">
                                                        <ProgressBar Style="{StaticResource DarkProgressBar}" Minimum="0" Maximum="1" Value="{Binding Progress}" />
                                                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource MicroText}" Margin="0,7,0,0" />
                                                    </StackPanel>

                                                    <!-- Installed -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,9,0,0"
                                                                Visibility="{Binding ShowInstalled, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="12"
                                                                   Foreground="{StaticResource LiveBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource MicroText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <!-- Error / cancelled status (only when a download was attempted) -->
                                                    <TextBlock Text="{Binding StatusText}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource MicroText}">
                                                                <Setter Property="Margin" Value="0,9,0,0" />
                                                                <Setter Property="TextWrapping" Value="Wrap" />
                                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanDownload}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StatusText}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource PrimaryButton}" Content="Download" Command="{Binding DownloadCommand}"
                                                            Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}" />
                                                    <Button Style="{StaticResource GhostButton}" Content="Cancel" Command="{Binding CancelCommand}"
                                                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Languages -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="LANGUAGES" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" />
                            <TextBlock Grid.Column="1" Text="&#xE72A;" FontFamily="{StaticResource IconFont}" FontSize="14"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="2" Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}" />
                        </Grid>
                    </Border>

                    <!-- Compute -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="COMPUTE DEVICE" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <ComboBox Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding DeviceItems}" SelectedItem="{Binding SelectedDevice}" />
                            <StackPanel Orientation="Horizontal" Margin="2,13,0,0">
                                <TextBlock Text="Model tier" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                                <Border Style="{StaticResource Badge}" Background="{StaticResource AccentSoftBrush}" Margin="9,0,0,0">
                                    <TextBlock Text="{Binding TierText}" Style="{StaticResource MonoText}" FontSize="11"
                                               Foreground="{StaticResource AccentBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="2,11,0,0" TextWrapping="Wrap" LineHeight="18"
                                       Text="Auto picks the fastest accelerator on this PC (TensorRT / CUDA → DirectML → CPU). One build runs on any GPU." />
                        </StackPanel>
                    </Border>

                    <!-- Overlay -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="OVERLAY" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Display style" Style="{StaticResource CaptionText}" Margin="2,0,0,7" />
                            <ComboBox Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding OverlayStyles}" SelectedItem="{Binding SelectedStyle}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumWords}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Live preview of the backplate -->
                            <Border Margin="0,16,0,0" Height="78" CornerRadius="10" ClipToBounds="True"
                                    Background="{StaticResource SurfaceInsetBrush}" BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <Grid>
                                    <TextBlock Text="你好，欢迎使用本程序" FontSize="17" Foreground="{StaticResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" />
                                    <Border CornerRadius="6" Background="#11141A" Padding="12,6" HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Opacity="{Binding BackplateOpacity}">
                                        <TextBlock Text="Hi, welcome to this program" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid Margin="2,18,0,0">
                                <TextBlock Text="Backplate opacity" Style="{StaticResource CaptionText}" />
                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource MonoText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding Value, ElementName=OpacitySlider, StringFormat={}{0:P0}}" />
                            </Grid>
                            <Slider x:Name="OpacitySlider" Style="{StaticResource DarkSlider}" Minimum="0.2" Maximum="1.0"
                                    Value="{Binding BackplateOpacity}" Margin="0,6,0,0" />

                            <Border Height="1" Background="{StaticResource HairlineBrush}" Margin="0,16,0,16" />

                            <CheckBox Style="{StaticResource ToggleSwitch}" Content="Auto-contrast backplate"
                                      IsChecked="{Binding AutoContrast}" />

                            <Grid Margin="2,18,0,0">
                                <TextBlock Text="Minimum text scale" Style="{StaticResource CaptionText}" />
                                <TextBlock HorizontalAlignment="Right" Style="{StaticResource MonoText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding Value, ElementName=ScaleSlider, StringFormat={}{0:P0}}" />
                            </Grid>
                            <Slider x:Name="ScaleSlider" Style="{StaticResource DarkSlider}" Minimum="0.4" Maximum="1.0"
                                    Value="{Binding MinFontScale}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Glossary -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="GLOSSARY" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="2,0,0,13" TextWrapping="Wrap" LineHeight="18"
                                       Text="Pin your own translations for names, jargon or app terms — they always win over machine translation." />

                            <!-- Empty state -->
                            <Border CornerRadius="10" Background="{StaticResource SurfaceInsetBrush}" Padding="14,16" Margin="0,0,0,10"
                                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                                    Visibility="{Binding GlossaryEntries.Count, Converter={StaticResource ZeroToVis}}">
                                <TextBlock Text="No terms yet. Add a Chinese word and the translation you prefer."
                                           Style="{StaticResource MicroText}" HorizontalAlignment="Center" />
                            </Border>

                            <ItemsControl ItemsSource="{Binding GlossaryEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="10" Padding="13,9" Margin="0,0,0,7"
                                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Source}" Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                                                    <TextBlock Text="&#xE72A;" FontFamily="{StaticResource IconFont}" FontSize="11"
                                                               Foreground="{StaticResource TextTertiaryBrush}" Margin="10,1,10,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Target}" Style="{StaticResource BodyText}"
                                                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="28" Height="28"
                                                        Content="&#xE74D;" FontSize="13" AutomationProperties.Name="Remove term"
                                                        Command="{Binding DataContext.RemoveGlossaryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,9,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}" Margin="0,0,8,0"
                                         ui:Placeholder.Text="Chinese term"
                                         Text="{Binding NewGlossarySource, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Margin="0,0,8,0"
                                         ui:Placeholder.Text="Your translation"
                                         Text="{Binding NewGlossaryTarget, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Add"
                                        Command="{Binding AddGlossaryCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- About -->
                    <StackPanel Style="{StaticResource SectionRow}">
                        <Border Width="3" Height="13" CornerRadius="2" Background="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}" Margin="9,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="LingoLens" Style="{StaticResource BodyStrong}" />
                                <TextBlock Text="{Binding AppVersion}" Style="{StaticResource MicroText}" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,6,0,0" TextWrapping="Wrap" LineHeight="18"
                                       Text="On-device screen translation. Nothing you see ever leaves your PC — capture, OCR and translation all run locally. Toggle the bar any time with Ctrl+Alt+H." />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
