<Window x:Class="LingoLens.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LingoLens — Settings"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="600" Height="700" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" UseLayoutRounding="True">

    <Window.Resources>
        <FontFamily x:Key="Icons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
    </Window.Resources>

    <Border Margin="14" CornerRadius="16" Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="52" MouseLeftButtonDown="OnDrag">
                <TextBlock Text="Settings" Style="{StaticResource TitleText}" Margin="22,0,0,0" VerticalAlignment="Center" />
                <Button Style="{StaticResource IconButton}" Content="&#xE8BB;" HorizontalAlignment="Right"
                        Margin="0,0,12,0" VerticalAlignment="Center" Click="OnClose" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,4,22,22">
                <StackPanel>

                    <!-- Compute -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="COMPUTE DEVICE" Style="{StaticResource SectionHeader}" />
                            <ComboBox Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding DeviceItems}" SelectedItem="{Binding SelectedDevice}" />
                            <StackPanel Orientation="Horizontal" Margin="2,10,0,0">
                                <TextBlock Text="Model tier:" Style="{StaticResource CaptionText}" />
                                <TextBlock Text="{Binding TierText}" Style="{StaticResource CaptionText}"
                                           Foreground="{StaticResource AccentBrush}" Margin="6,0,0,0" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource MicroText}" Margin="2,8,0,0" TextWrapping="Wrap"
                                       Text="Auto picks the fastest available accelerator (TensorRT/CUDA → DirectML → CPU). One build runs on any GPU." />
                        </StackPanel>
                    </Border>

                    <!-- Languages -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="LANGUAGES" Style="{StaticResource SectionHeader}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" />
                                <TextBlock Grid.Column="1" Text="&#xE72A;" FontFamily="{StaticResource Icons}"
                                           Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="2" Style="{StaticResource DarkComboBox}"
                                          ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Overlay -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="OVERLAY" Style="{StaticResource SectionHeader}" />
                            <TextBlock Text="Display style" Style="{StaticResource CaptionText}" Margin="2,0,0,6" />
                            <ComboBox Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding OverlayStyles}" SelectedItem="{Binding SelectedStyle}" />

                            <Grid Margin="2,14,0,0">
                                <TextBlock Text="Backplate opacity" Style="{StaticResource CaptionText}" />
                            </Grid>
                            <Slider Style="{StaticResource DarkSlider}" Minimum="0.2" Maximum="1.0"
                                    Value="{Binding BackplateOpacity}" Margin="0,4,0,0" />

                            <CheckBox Content="Auto-contrast backplate" IsChecked="{Binding AutoContrast}"
                                      Foreground="{StaticResource TextPrimaryBrush}" Margin="2,12,0,0" />

                            <TextBlock Text="Minimum text scale" Style="{StaticResource CaptionText}" Margin="2,12,0,0" />
                            <Slider Style="{StaticResource DarkSlider}" Minimum="0.4" Maximum="1.0"
                                    Value="{Binding MinFontScale}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Glossary -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="GLOSSARY" Style="{StaticResource SectionHeader}" />
                            <TextBlock Style="{StaticResource MicroText}" Margin="2,0,0,8" TextWrapping="Wrap"
                                       Text="Custom term overrides take priority over machine translation." />
                            <ItemsControl ItemsSource="{Binding GlossaryEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8" Padding="10,7" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Source}" Style="{StaticResource BodyText}" />
                                                    <TextBlock Text="  →  " Style="{StaticResource CaptionText}" />
                                                    <TextBlock Text="{Binding Target}" Style="{StaticResource BodyText}"
                                                               Foreground="{StaticResource AccentBrush}" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="26" Height="26"
                                                        Content="&#xE74D;"
                                                        Command="{Binding DataContext.RemoveGlossaryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}" Margin="0,0,6,0"
                                         Text="{Binding NewGlossarySource, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" Margin="0,0,6,0"
                                         Text="{Binding NewGlossaryTarget, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="Add"
                                        Command="{Binding AddGlossaryCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- About -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}" />
                            <TextBlock Text="LingoLens" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource MicroText}" Margin="0,4,0,0" TextWrapping="Wrap"
                                       Text="On-device screen translation. Nothing you see ever leaves your PC — capture, OCR and translation all run locally." />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
