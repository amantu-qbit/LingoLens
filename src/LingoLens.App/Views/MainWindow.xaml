<Window x:Class="LingoLens.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LingoLens"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Topmost="True" ShowInTaskbar="True" WindowStartupLocation="Manual"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <FontFamily x:Key="Icons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

        <!-- Session chip: a quiet, rounded button for the target + language readouts. -->
        <Style x:Key="SessionChip" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="11" Background="{StaticResource BackgroundBrush}"
                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- The bar. Outer margin = shadow room; generous, even padding keeps every control off the edge. -->
    <Border Margin="22" CornerRadius="20" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="OnDragArea_MouseDown" Padding="16,13">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="4" Opacity="0.5" Color="Black" />
        </Border.Effect>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- Brand: a small aperture -->
            <Grid Width="30" Height="30" VerticalAlignment="Center" Margin="2,0,0,0">
                <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2.2" />
                <Ellipse Width="12" Height="12" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4" Opacity="0.6" />
                <Ellipse Width="4" Height="4" Fill="{StaticResource AccentBrush}" />
            </Grid>

            <!-- Primary action: the visual anchor -->
            <Button Command="{Binding ToggleRunCommand}" Margin="14,0,0,0" Height="42" MinWidth="134"
                    VerticalAlignment="Center" Cursor="Hand" Foreground="{StaticResource AccentInkBrush}"
                    FontFamily="{StaticResource UiFont}" FontSize="13.5" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="12" Background="{StaticResource AccentBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource Icons}" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE768;" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="&#xE71A;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding RunLabel}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Session: what is being translated + the direction, grouped together -->
            <Button Style="{StaticResource SessionChip}" Command="{Binding PickTargetCommand}"
                    Margin="12,0,0,0" ToolTip="Choose what to translate">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource Icons}" Text="&#xE7C5;" FontSize="14"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TargetName}" VerticalAlignment="Center"
                               MaxWidth="190" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>

            <Button Style="{StaticResource SessionChip}" Command="{Binding OpenSettingsCommand}"
                    Margin="8,0,0,0" ToolTip="Change languages">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource Icons}" Text="&#xF2B7;" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LanguagePair}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Button>

            <!-- Contextual status: telemetry while translating -->
            <Border Margin="12,0,0,0" CornerRadius="11" Background="{StaticResource AccentSoftBrush}"
                    Padding="13,0" Height="40" VerticalAlignment="Center"
                    Visibility="{Binding ShowTelemetry, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding LatencyText}" Style="{StaticResource MonoText}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CacheText}" Style="{StaticResource MonoText}"
                               Foreground="{StaticResource TextTertiaryBrush}" Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Download progress -->
            <Border Margin="12,0,0,0" CornerRadius="11" Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" Padding="14,0"
                    Height="40" VerticalAlignment="Center" MinWidth="210"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock FontFamily="{StaticResource Icons}" Text="&#xE896;" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,9,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DownloadStatus}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ProgressBar Style="{StaticResource DarkProgressBar}" Minimum="0" Maximum="1" Value="{Binding DownloadProgress}" />
                </StackPanel>
            </Border>

            <!-- Warning (e.g. no translation model ready) -->
            <Border Margin="12,0,0,0" CornerRadius="11" Background="#26E2C275"
                    BorderBrush="#59E2C275" BorderThickness="1" Padding="13,0" Height="40"
                    VerticalAlignment="Center" ToolTip="{Binding StatusText}"
                    Visibility="{Binding HasIssue, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource Icons}" Text="&#xE7BA;" FontSize="14"
                               Foreground="{StaticResource WarningBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                               MaxWidth="300" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Rectangle Width="1" Height="28" Fill="{StaticResource HairlineBrush}" Margin="14,0" VerticalAlignment="Center" />

            <!-- Utilities -->
            <Button Style="{StaticResource IconButton}" Width="34" Height="34" Command="{Binding OpenSettingsCommand}"
                    ToolTip="{Binding DeviceName}" Content="&#xEC4A;" VerticalAlignment="Center" />
            <Button Style="{StaticResource IconButton}" Width="34" Height="34" Command="{Binding OpenSettingsCommand}"
                    ToolTip="Settings" Content="&#xE713;" Margin="2,0,0,0" VerticalAlignment="Center" />
            <Button Style="{StaticResource IconButton}" Width="34" Height="34" Click="OnHide"
                    ToolTip="Hide bar  (Ctrl+Alt+H to toggle)" Content="&#xED1A;" Margin="2,0,0,0" VerticalAlignment="Center" />
            <Button Style="{StaticResource IconButton}" Width="34" Height="34" Click="OnMinimize"
                    ToolTip="Minimize" Content="&#xE921;" Margin="2,0,0,0" VerticalAlignment="Center" />
            <Button Style="{StaticResource IconButton}" Width="34" Height="34" Click="OnClose"
                    ToolTip="Exit" Content="&#xE8BB;" Margin="2,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
