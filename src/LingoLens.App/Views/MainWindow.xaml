<Window x:Class="LingoLens.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LingoLens"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Topmost="True" ShowInTaskbar="True" WindowStartupLocation="Manual"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <FontFamily x:Key="Icons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

        <!-- A single chip: leading glyph + label, consistent height and padding. -->
        <Style x:Key="HudChip" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <!-- Outer margin leaves room for the soft window shadow. Generous inner padding keeps every
         control clear of the rounded border. -->
    <Border Margin="20" CornerRadius="17" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="OnDragArea_MouseDown" Padding="14,12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="3" Opacity="0.5" Color="Black" />
        </Border.Effect>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- Lens brand mark -->
            <Grid Width="28" Height="28" Margin="2,0,4,0" VerticalAlignment="Center">
                <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2" />
                <Ellipse Width="11" Height="11" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.4" Opacity="0.65" />
                <Ellipse Width="4" Height="4" Fill="{StaticResource AccentBrush}" />
            </Grid>

            <!-- Primary Translate / Stop -->
            <Button Style="{StaticResource PrimaryButton}" Command="{Binding ToggleRunCommand}"
                    Margin="8,0,0,0" Height="38" MinWidth="124" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource Icons}" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE768;" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="&#xE71A;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding RunLabel}" VerticalAlignment="Center" FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <Rectangle Width="1" Height="26" Fill="{StaticResource HairlineBrush}" Margin="14,0" VerticalAlignment="Center" />

            <!-- Target -->
            <Button Style="{StaticResource HudChip}" Command="{Binding PickTargetCommand}" ToolTip="Choose what to translate">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource Icons}" Text="&#xE7C5;" FontSize="14"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,9,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TargetName}" VerticalAlignment="Center" Style="{StaticResource BodyText}"
                               MaxWidth="180" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>

            <!-- Language -->
            <Button Style="{StaticResource HudChip}" Command="{Binding OpenSettingsCommand}" Margin="8,0,0,0" ToolTip="Languages">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource Icons}" Text="&#xF2B7;" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,9,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LanguagePair}" VerticalAlignment="Center" Style="{StaticResource BodyText}" />
                </StackPanel>
            </Button>

            <!-- Device -->
            <Button Style="{StaticResource HudChip}" Command="{Binding OpenSettingsCommand}" Margin="8,0,0,0" ToolTip="Compute device">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource Icons}" Text="&#xEC4A;" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,9,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DeviceName}" VerticalAlignment="Center" Style="{StaticResource CaptionText}"
                               MaxWidth="150" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>

            <!-- Contextual status zone: telemetry / download / warning -->
            <Border Margin="14,0,0,0" CornerRadius="9" Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" Padding="12,7"
                    VerticalAlignment="Center"
                    Visibility="{Binding ShowTelemetry, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                    <TextBlock Text="{Binding LatencyText}" Style="{StaticResource MonoText}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CacheText}" Style="{StaticResource MonoText}"
                               Foreground="{StaticResource TextTertiaryBrush}" Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Download progress -->
            <Border Margin="14,0,0,0" CornerRadius="9" Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" Padding="13,7"
                    VerticalAlignment="Center" MinWidth="200"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource Icons}" Text="&#xE896;" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DownloadStatus}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ProgressBar Style="{StaticResource DarkProgressBar}" Margin="0,7,0,0"
                                 Minimum="0" Maximum="1" Value="{Binding DownloadProgress}" />
                </StackPanel>
            </Border>

            <!-- Warning (e.g. no translation model ready) -->
            <Border Margin="14,0,0,0" CornerRadius="9" Background="#26E2C275"
                    BorderBrush="#66E2C275" BorderThickness="1" Padding="12,7"
                    VerticalAlignment="Center"
                    ToolTip="{Binding StatusText}"
                    Visibility="{Binding HasIssue, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource Icons}" Text="&#xE7BA;" FontSize="13"
                               Foreground="{StaticResource WarningBrush}" Margin="0,0,9,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                               MaxWidth="320" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Rectangle Width="1" Height="26" Fill="{StaticResource HairlineBrush}" Margin="14,0" VerticalAlignment="Center" />

            <!-- Window controls -->
            <Button Style="{StaticResource IconButton}" Command="{Binding OpenSettingsCommand}" ToolTip="Settings" Content="&#xE713;" VerticalAlignment="Center" />
            <Button Style="{StaticResource IconButton}" Click="OnHide" ToolTip="Hide bar  (Ctrl+Alt+H to toggle)" Content="&#xED1A;" Margin="2,0,0,0" VerticalAlignment="Center" />
            <Button Style="{StaticResource IconButton}" Click="OnMinimize" ToolTip="Minimize" Content="&#xE921;" Margin="2,0,0,0" VerticalAlignment="Center" />
            <Button Style="{StaticResource IconButton}" Click="OnClose" ToolTip="Exit" Content="&#xE8BB;" Margin="2,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
