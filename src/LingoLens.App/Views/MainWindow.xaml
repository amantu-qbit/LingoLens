<Window x:Class="LingoLens.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LingoLens"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Topmost="True" ShowInTaskbar="True" WindowStartupLocation="Manual"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <!-- Session chip: a quiet inset button for the target + language readouts. -->
        <Style x:Key="SessionChip" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="11" Background="{StaticResource SurfaceInsetBrush}"
                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer margin = shadow room. The bar lifts + fades in on launch. -->
    <Border x:Name="Bar" Margin="22" CornerRadius="20" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="OnDragArea_MouseDown" Padding="15,12" RenderTransformOrigin="0.5,1">
        <Border.RenderTransform>
            <TranslateTransform x:Name="BarLift" Y="14" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="38" ShadowDepth="6" Opacity="0.55" Color="Black" />
        </Border.Effect>
        <Border.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22"
                                         EasingFunction="{StaticResource EaseOut}" />
                        <DoubleAnimation Storyboard.TargetName="BarLift" Storyboard.TargetProperty="Y"
                                         From="14" To="0" Duration="0:0:0.30" EasingFunction="{StaticResource EaseOut}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- Brand: a lens dispersing light — prism-gradient rings, core goes emerald + breathes while translating -->
            <Grid Width="30" Height="30" VerticalAlignment="Center" Margin="3,0,0,0">
                <Ellipse Stroke="{StaticResource PrismGradient}" StrokeThickness="2.4" />
                <Ellipse Width="13" Height="13" Stroke="{StaticResource PrismGradient}" StrokeThickness="1.6" Opacity="0.7" />
                <Ellipse x:Name="BrandCore" Width="5" Height="5" Fill="{StaticResource AccentBrush}">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource LiveBrush}" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="CorePulse">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.35"
                                                                 Duration="0:0:1.1" AutoReverse="True" RepeatBehavior="Forever"
                                                                 EasingFunction="{StaticResource EaseInOut}" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="CorePulse" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>

            <!-- Primary action: the amber anchor. Glyph + label switch with run state. -->
            <Button Command="{Binding ToggleRunCommand}" Margin="15,0,0,0" Height="42" MinWidth="140"
                    VerticalAlignment="Center" Cursor="Hand" Foreground="{StaticResource AccentInkBrush}"
                    FontFamily="{StaticResource UiFont}" FontSize="13.5" FontWeight="SemiBold"
                    FocusVisualStyle="{x:Null}" AutomationProperties.Name="{Binding RunLabel}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ring" CornerRadius="13" Margin="-3" BorderThickness="2"
                                    BorderBrush="{StaticResource AccentLineBrush}" Opacity="0" />
                            <Border x:Name="bd" CornerRadius="12" Background="{StaticResource GoGradient}"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="sc" ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <Grid>
                                    <Border x:Name="veil" CornerRadius="12" Background="#FFFFFF" Opacity="0" />
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource StopGradient}" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="veil" Property="Opacity" Value="0.14" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ring" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.92" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.07" />
                                            <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="0.97" Duration="0:0:0.07" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12" EasingFunction="{StaticResource EaseOut}" />
                                            <DoubleAnimation Storyboard.TargetName="sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12" EasingFunction="{StaticResource EaseOut}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE768;" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="&#xE71A;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding RunLabel}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Session: what's being translated -->
            <Button Style="{StaticResource SessionChip}" Command="{Binding PickTargetCommand}"
                    Margin="12,0,0,0" ToolTip="Choose what to translate"
                    AutomationProperties.Name="Choose what to translate">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE7C5;" FontSize="14"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TargetName}" VerticalAlignment="Center"
                               MaxWidth="190" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>

            <!-- Direction -->
            <Button Style="{StaticResource SessionChip}" Command="{Binding OpenSettingsCommand}"
                    Margin="8,0,0,0" ToolTip="Change languages"
                    AutomationProperties.Name="Change languages">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xF2B7;" FontSize="14"
                               Foreground="{StaticResource HueViolet}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LanguagePair}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Button>

            <!-- Live telemetry while translating cleanly -->
            <Border Margin="12,0,0,0" CornerRadius="11" Background="{StaticResource LiveSoftBrush}"
                    BorderBrush="{StaticResource LiveLineBrush}" BorderThickness="1"
                    Padding="13,0" Height="40" VerticalAlignment="Center"
                    Visibility="{Binding ShowTelemetry, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="LiveDot" Width="7" Height="7" Fill="{StaticResource LiveBrush}"
                             VerticalAlignment="Center" Margin="0,0,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="DotPulse">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3"
                                                                     Duration="0:0:1.1" AutoReverse="True" RepeatBehavior="Forever"
                                                                     EasingFunction="{StaticResource EaseInOut}" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="DotPulse" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding LatencyText}" Style="{StaticResource MonoText}"
                               Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CacheText}" Style="{StaticResource MonoText}"
                               Foreground="{StaticResource TextTertiaryBrush}" Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Download progress -->
            <Border Margin="12,0,0,0" CornerRadius="11" Background="{StaticResource SurfaceInsetBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" Padding="14,0"
                    Height="40" VerticalAlignment="Center" MinWidth="214"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE896;" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,9,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DownloadStatus}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ProgressBar Style="{StaticResource DarkProgressBar}" Minimum="0" Maximum="1" Value="{Binding DownloadProgress}" />
                </StackPanel>
            </Border>

            <!-- Attention (e.g. no translation model yet) — warning orange, distinct from the amber action -->
            <Border Margin="12,0,0,0" CornerRadius="11" Background="{StaticResource WarningSoftBrush}"
                    BorderBrush="{StaticResource WarningLineBrush}" BorderThickness="1" Padding="13,0" Height="40"
                    VerticalAlignment="Center" ToolTip="{Binding StatusText}"
                    Visibility="{Binding HasIssue, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE7BA;" FontSize="14"
                               Foreground="{StaticResource WarningBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                               MaxWidth="300" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Rectangle Width="1" Height="26" Fill="{StaticResource HairlineBrush}" Margin="14,0" VerticalAlignment="Center" />

            <!-- Utilities -->
            <Button Style="{StaticResource IconButton}" Command="{Binding OpenSettingsCommand}"
                    ToolTip="{Binding DeviceName}" Content="&#xEC4A;" VerticalAlignment="Center"
                    AutomationProperties.Name="Compute device" />
            <Button Style="{StaticResource IconButton}" Command="{Binding OpenSettingsCommand}"
                    ToolTip="Settings" Content="&#xE713;" Margin="2,0,0,0" VerticalAlignment="Center"
                    AutomationProperties.Name="Settings" />
            <Button Style="{StaticResource IconButton}" Click="OnHide"
                    ToolTip="Hide bar  ·  Ctrl+Alt+H to bring back" Content="&#xED1A;" Margin="2,0,0,0" VerticalAlignment="Center"
                    AutomationProperties.Name="Hide bar" />
            <Button Style="{StaticResource IconButton}" Click="OnMinimize"
                    ToolTip="Minimize" Content="&#xE921;" Margin="2,0,0,0" VerticalAlignment="Center"
                    AutomationProperties.Name="Minimize" />
            <Button Style="{StaticResource IconButton}" Click="OnClose"
                    ToolTip="Exit LingoLens" Content="&#xE8BB;" Margin="2,0,0,0" VerticalAlignment="Center"
                    AutomationProperties.Name="Exit" />
        </StackPanel>
    </Border>
</Window>
