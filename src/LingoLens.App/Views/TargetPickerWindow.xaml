<Window x:Class="LingoLens.App.Views.TargetPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose a target"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="520" Height="600" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" UseLayoutRounding="True">

    <Border Margin="14" CornerRadius="16" Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="Black" />
        </Border.Effect>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="52" MouseLeftButtonDown="OnDrag">
                <TextBlock Text="What should we translate?" Style="{StaticResource TitleText}"
                           Margin="22,0,0,0" VerticalAlignment="Center" />
                <Button Style="{StaticResource IconButton}" Content="&#xE8BB;" HorizontalAlignment="Right"
                        Margin="0,0,12,0" VerticalAlignment="Center" Click="OnCancel" />
            </Grid>

            <TextBlock Grid.Row="1" Text="OPEN WINDOWS" Style="{StaticResource SectionHeader}" Margin="22,4,0,8" />

            <!-- Windows list -->
            <Border Grid.Row="2" Margin="18,0,18,0" CornerRadius="12" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <ListBox x:Name="WindowsList" Background="Transparent" BorderThickness="0" Margin="6"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="OnWindowDoubleClick">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" CornerRadius="8" Padding="12,9" Margin="2" Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ProcessName}" Style="{StaticResource MicroText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Footer: monitor + region + actions -->
            <StackPanel Grid.Row="3" Margin="18,14,18,18">
                <TextBlock Text="OR CAPTURE" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="MonitorsCombo" Grid.Column="0" Style="{StaticResource DarkComboBox}" Margin="0,0,8,0" />
                    <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="Use monitor" Click="OnUseMonitor" Margin="0,0,8,0" />
                    <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="Draw region…" Click="OnDrawRegion" />
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="OnCancel" Margin="0,0,8,0" />
                    <Button Style="{StaticResource PrimaryButton}" Content="Translate this window" Click="OnUseWindow" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
