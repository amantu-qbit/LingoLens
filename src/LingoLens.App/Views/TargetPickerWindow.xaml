<Window x:Class="LingoLens.App.Views.TargetPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:LingoLens.App.Ui"
        Title="Choose a target"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="568" Height="684" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

    <Border x:Name="Root" Margin="14" CornerRadius="18" Background="{StaticResource CanvasBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="OnDrag" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="Lift" Y="12" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="4" Opacity="0.6" Color="Black" />
        </Border.Effect>
        <Border.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.20"
                                         EasingFunction="{StaticResource EaseOut}" />
                        <DoubleAnimation Storyboard.TargetName="Lift" Storyboard.TargetProperty="Y"
                                         From="12" To="0" Duration="0:0:0.26" EasingFunction="{StaticResource EaseOut}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Height="64">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                    <Grid Width="24" Height="24" Margin="0,0,13,0">
                        <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2" />
                        <Ellipse Width="9" Height="9" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.3" Opacity="0.6" />
                        <Ellipse Width="3.5" Height="3.5" Fill="{StaticResource AccentBrush}" />
                    </Grid>
                    <TextBlock Text="Choose what to translate" Style="{StaticResource TitleText}" VerticalAlignment="Center" />
                </StackPanel>
                <Button Style="{StaticResource IconButton}" Content="&#xE8BB;" HorizontalAlignment="Right"
                        Margin="0,0,16,0" VerticalAlignment="Center" Click="OnCancel"
                        AutomationProperties.Name="Cancel" />
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource HairlineBrush}" Margin="22,0" />

            <!-- Search -->
            <Border Grid.Row="2" Margin="22,16,22,0" CornerRadius="10" Height="40"
                    Background="{StaticResource SurfaceInsetBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="14"
                               Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="13,0,0,0" />
                    <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource AccentBrush}"
                             SelectionBrush="{StaticResource AccentBrush}" FontFamily="{StaticResource UiFont}" FontSize="13"
                             VerticalContentAlignment="Center" Margin="10,0,12,0"
                             ui:Placeholder.Text="Search open windows…" TextChanged="OnSearchChanged">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Grid>
                                    <TextBlock IsHitTestVisible="False" VerticalAlignment="Center"
                                               FontFamily="{StaticResource UiFont}" FontSize="13"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               Text="{Binding Path=(ui:Placeholder.Text), RelativeSource={RelativeSource TemplatedParent}}"
                                               Visibility="{Binding Path=Text, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyToVis}}" />
                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                                </Grid>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>
                </Grid>
            </Border>

            <!-- Windows list / loading / empty -->
            <Grid Grid.Row="3" Margin="18,12,18,0">
                <ListBox x:Name="WindowsList" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling"
                         ScrollViewer.CanContentScroll="True"
                         ItemContainerStyle="{StaticResource ListRow}"
                         MouseDoubleClick="OnWindowDoubleClick" KeyDown="OnListKeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- App icon, with a neutral tile fallback -->
                                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9"
                                        Background="{StaticResource SurfaceRaisedBrush}" Margin="0,0,13,0">
                                    <Grid>
                                        <TextBlock Text="&#xE737;" FontFamily="{StaticResource IconFont}" FontSize="15"
                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Image Source="{Binding Icon}" Width="20" Height="20"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ProcessName}" Style="{StaticResource MicroText}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Loading -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid Width="30" Height="30" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="SpinRotate" />
                        </Grid.RenderTransform>
                        <Ellipse Width="30" Height="30" Stroke="{StaticResource SurfaceRaisedBrush}" StrokeThickness="3" />
                        <Ellipse Width="30" Height="30" Stroke="{StaticResource AccentBrush}" StrokeThickness="3"
                                 StrokeDashArray="6 100" StrokeDashCap="Round" />
                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SpinRotate" Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:0.9" RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>
                    </Grid>
                    <TextBlock Text="Finding open windows…" Style="{StaticResource MicroText}" Margin="0,12,0,0" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Empty / no matches -->
                <StackPanel x:Name="EmptyPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="22"
                               Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="EmptyLabel" Text="No matching windows." Style="{StaticResource MicroText}"
                               Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Capture a whole screen or a region -->
            <StackPanel Grid.Row="4" Margin="22,14,22,20">
                <Rectangle Height="1" Fill="{StaticResource HairlineBrush}" Margin="0,0,0,16" />
                <TextBlock Text="OR CAPTURE A SCREEN" Style="{StaticResource SectionHeader}" Margin="2,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Monitor -->
                    <Border Grid.Column="0" CornerRadius="12" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="MonitorsCombo" Grid.Column="0" Style="{StaticResource DarkComboBox}" Margin="0,0,10,0" />
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Capture" Click="OnUseMonitor" />
                        </Grid>
                    </Border>

                    <!-- Region -->
                    <Button Grid.Column="2" Style="{StaticResource GhostButton}" Click="OnDrawRegion" Padding="18,0" Height="64"
                            AutomationProperties.Name="Draw a region">
                        <StackPanel>
                            <TextBlock Text="&#xE7A8;" FontFamily="{StaticResource IconFont}" FontSize="16"
                                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="Draw region" Style="{StaticResource CaptionText}" Margin="0,5,0,0" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="OnCancel" Margin="0,0,8,0" MinWidth="92" />
                    <Button Style="{StaticResource PrimaryButton}" Content="Translate this window" Click="OnUseWindow" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
